package com.loiane.cursojava.aula19.labs;

public class Ex32 {

	public static void main(String[] args) {
		int[] a = new int[5];
		for(int i = 0; i < a.length; i++) {
			a[i] = i;
		}
		
		
		for(int i = 0; i < a.length; i++) {
			if(i == 0) {
				System.out.println("Vector a = {" + a[i] + ", ");
			} else if(i == a.length - 1) {
				System.out.println(a[i] + "}");
			} else {
				System.out.println(a[i] + " ");
			}
		}

	}

}
