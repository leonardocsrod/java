package com.loiane.cursojava.aula19.labs;

public class Ex37 {

	public static void main(String[] args) {
		int[] a = new int[5];
		
		for(int i = 0; i < a.length; i++) {
			for(int j = 1; j <= i; j++) {
				a[i] = i * j;
			}
		}
		
		for(int i = 0; i < a.length; i++) {
			if(i == 0) {
				System.out.print("Vector a = {" + a[i] + ", ");
			} else if(i == a.length - 1) {
				System.out.println(a[i] + "}\n");
			} else {
				System.out.print(a[i] + ", ");
			}
		}

	}

}
