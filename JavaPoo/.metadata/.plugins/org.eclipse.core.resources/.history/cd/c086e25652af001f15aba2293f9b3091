package pooIfce;

public class NumeroPrimo {
	
	public static void main(String[] args) {
		int cont = 1;
		int i = 0;
		int j = 0;
		for(i = 0; i <= 100; i++) {
			for(j = 1, cont = 1; j <= i; j++) {
				if(1 % j == 0) {
					cont++;
				}
				
			}
			if(cont == 2) {
				System.out.println("O número " + i + " é primo.");
			}
			System.out.println(i);
		}

	}

}
